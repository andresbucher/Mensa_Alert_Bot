TELEGRAM_BOT_TOKEN=replace_with_new_token
# Optional default chat id; can also be set using /setchat
ALERT_CHAT_ID=

# 0=Monday, 6=Sunday
CHECK_WEEKDAY=0
CHECK_TIME=08:00
TIMEZONE=Europe/Zurich

# Online scraping sources: comma-separated "Cantine Name|URL" pairs
# Example:
# CANTINE_SOURCES=Polyterasse|https://example.org/poly,Klausius Mensa|https://example.org/klausius
# Date handling:
# - Use {week_monday} placeholder, or
# - Include date=... query param and it will be replaced automatically each week.
# ETH example:
# CANTINE_SOURCES=Polyterasse|https://ethz.ch/de/campus/erleben/gastronomie-und-einkaufen/gastronomie/menueplaene/offerWeek.html?date={week_monday}&id=9
CANTINE_SOURCES=

# Comma-separated keywords to scan for
SPECIAL_KEYWORDS=crispy beef,truffle pasta,sushi bowl

# Optional comma-separated cantine names to include
CANTINE_NAMES=

# Used by weekly_runner.py (GitHub Actions) to allow a time window
RUN_WINDOW_MINUTES=20

STATE_FILE=bot_state.json
